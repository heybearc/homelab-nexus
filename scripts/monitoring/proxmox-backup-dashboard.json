{
  "dashboard": {
    "title": "Proxmox Backups",
    "tags": ["proxmox", "backups", "infrastructure"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5m",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Backup Coverage Overview",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "count(proxmox_backup_last_success > 0)",
            "refId": "A",
            "legendFormat": "Containers with Backups"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "justifyMode": "center",
          "textMode": "value_and_name",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 30, "color": "yellow"},
                {"value": 38, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Containers Without Recent Backups",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "count(proxmox_backup_last_success == 0 or (time() - proxmox_backup_last_success) > 172800)",
            "refId": "A",
            "legendFormat": "Missing/Stale Backups"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "justifyMode": "center",
          "textMode": "value_and_name",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Oldest Backup Age",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "max(time() - proxmox_backup_last_success{ctid!=\"\"})",
            "refId": "A",
            "legendFormat": "Oldest Backup"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "justifyMode": "center",
          "textMode": "value_and_name",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 172800, "color": "yellow"},
                {"value": 604800, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Last Metrics Update",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "time() - proxmox_backup_metrics_updated",
            "refId": "A",
            "legendFormat": "Time Since Update"
          }
        ],
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "justifyMode": "center",
          "textMode": "value_and_name",
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 7200, "color": "yellow"},
                {"value": 14400, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Backup Age by Container",
        "type": "bargauge",
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "(time() - proxmox_backup_last_success{ctid!=\"\"}) / 3600",
            "refId": "A",
            "legendFormat": "CT{{ctid}}"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true,
          "reduceOptions": {
            "values": false,
            "calcs": ["lastNotNull"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "h",
            "min": 0,
            "max": 168,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 48, "color": "yellow"},
                {"value": 168, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Last Successful Backup Time",
        "type": "table",
        "gridPos": {
          "x": 12,
          "y": 4,
          "w": 12,
          "h": 8
        },
        "targets": [
          {
            "expr": "proxmox_backup_last_success{ctid!=\"\"}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "instance": true,
                "job": true
              },
              "indexByName": {
                "ctid": 0,
                "Value": 1
              },
              "renameByName": {
                "ctid": "Container",
                "Value": "Last Backup (Unix)"
              }
            }
          },
          {
            "id": "convertFieldType",
            "options": {
              "conversions": [
                {
                  "destinationType": "time",
                  "targetField": "Last Backup (Unix)"
                }
              ]
            }
          },
          {
            "id": "sortBy",
            "options": {
              "fields": {},
              "sort": [
                {
                  "field": "Last Backup (Unix)",
                  "desc": false
                }
              ]
            }
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": []
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "left",
              "filterable": true
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Last Backup (Unix)"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "dateTimeFromNow"
                },
                {
                  "id": "custom.cellOptions",
                  "value": {
                    "type": "color-text"
                  }
                },
                {
                  "id": "thresholds",
                  "value": {
                    "mode": "absolute",
                    "steps": [
                      {"value": 0, "color": "red"},
                      {"value": 1, "color": "green"}
                    ]
                  }
                }
              ]
            }
          ]
        }
      },
      {
        "id": 7,
        "title": "Backup Age Trend (Last 7 Days)",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 12,
          "w": 24,
          "h": 8
        },
        "targets": [
          {
            "expr": "(time() - proxmox_backup_last_success{ctid=~\"131|132|133|134|135|136|137|138|139|141|150|151|181|182\"}) / 3600",
            "refId": "A",
            "legendFormat": "CT{{ctid}} (Tier 1)"
          }
        ],
        "options": {
          "tooltip": {
            "mode": "multi",
            "sort": "none"
          },
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "calcs": ["lastNotNull", "min", "max"]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "h",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "fillOpacity": 10,
              "showPoints": "never"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 48, "color": "yellow"},
                {"value": 168, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Containers Missing Backups",
        "type": "table",
        "gridPos": {
          "x": 0,
          "y": 20,
          "w": 12,
          "h": 6
        },
        "targets": [
          {
            "expr": "proxmox_backup_last_success{ctid!=\"\"} == 0",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "instance": true,
                "job": true,
                "Value": true
              },
              "indexByName": {
                "ctid": 0
              },
              "renameByName": {
                "ctid": "Container ID"
              }
            }
          }
        ],
        "options": {
          "showHeader": true
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "left"
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Stale Backups (>48 hours old)",
        "type": "table",
        "gridPos": {
          "x": 12,
          "y": 20,
          "w": 12,
          "h": 6
        },
        "targets": [
          {
            "expr": "proxmox_backup_last_success{ctid!=\"\"} > 0 and (time() - proxmox_backup_last_success{ctid!=\"\"}) > 172800",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "instance": true,
                "job": true
              },
              "indexByName": {
                "ctid": 0,
                "Value": 1
              },
              "renameByName": {
                "ctid": "Container",
                "Value": "Last Backup"
              }
            }
          },
          {
            "id": "convertFieldType",
            "options": {
              "conversions": [
                {
                  "destinationType": "time",
                  "targetField": "Last Backup"
                }
              ]
            }
          }
        ],
        "options": {
          "showHeader": true
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "left"
            }
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Last Backup"
              },
              "properties": [
                {
                  "id": "unit",
                  "value": "dateTimeFromNow"
                }
              ]
            }
          ]
        }
      }
    ],
    "templating": {
      "list": []
    },
    "annotations": {
      "list": []
    }
  },
  "overwrite": true,
  "folderId": 0
}
