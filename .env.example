# Automated Container Provisioning Pipeline Configuration
# Copy this file to .env and fill in your credentials

# Proxmox
PROXMOX_HOST=10.92.0.5

# Netbox IPAM
NETBOX_URL=http://10.92.3.11
NETBOX_TOKEN=your-netbox-api-token-here

# Nginx Proxy Manager
NPM_URL=http://10.92.3.33:81
NPM_EMAIL=admin@cloudigan.net
NPM_PASSWORD=your-npm-password-here

# AdGuard Home DNS
ADGUARD_URL=http://10.92.3.10
ADGUARD_USER=admin
ADGUARD_PASSWORD=your-adguard-password-here

# TrueNAS
TRUENAS_HOST=10.92.0.3

# Monitoring
LOKI_URL=http://10.92.3.2:3100

# Backup
BACKUP_STORAGE=local
BACKUP_TIME=02:00
BACKUP_RETENTION=keep-last=7,keep-weekly=4,keep-monthly=3

# n8n Automation Platform
N8N_API_URL=https://n8n.cloudigan.net/api/v1
N8N_API_TOKEN=your-n8n-api-token-here

# Vikunja Task Management
VIKUNJA_API_URL=https://vikunja.cloudigan.net/api/v1
VIKUNJA_API_TOKEN=your-vikunja-api-token-here

# LibreTranslate API
LIBRETRANSLATE_API_URL=https://libretranslate.cloudigan.net
LIBRETRANSLATE_API_KEY=your-libretranslate-api-key-here
